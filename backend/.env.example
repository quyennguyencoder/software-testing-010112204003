############################################################
# Environment variables for UTE PhoneHub (Template)
# Đổi tên file này thành `.env` ở root hoặc trong thư mục backend/
# trước khi chạy `docker compose up`.
############################################################

########################
# Database (Postgres)
########################
POSTGRES_USER=utephonehub
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=utephonehub_db

# Spring datasource (thường trùng với Postgres ở trên)
DB_HOST=postgres
DB_USERNAME=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}

########################
# Redis
########################
REDIS_HOST=redis

########################
# Mail (SMTP)
########################
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_app_password


########################
# Google OAuth2
########################
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

########################
# JWT
########################
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

########################
# VNPay
########################
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_RETURN_URL=http://localhost:8081/api/v1/payments/vnpay/return

########################
# Server
########################
SERVER_PORT=8081

########################
# Frontend
########################
# URL base của API backend cho frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8081/api/v1

# Frontend URL Configuration
FRONTEND_URL=http://localhost:3000

########################
# Gemini AI (Chatbot) - Primary Key
########################
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

########################
# Gemini AI - Fallback Keys
########################
GEMINI_API_KEY_1=your_gemini_api_key_1
GEMINI_API_KEY_2=your_gemini_api_key_2
GEMINI_API_KEY_3=your_gemini_api_key_3
GEMINI_API_KEY_4=your_gemini_api_key_4
GEMINI_API_KEY_5=your_gemini_api_key_5
GEMINI_API_KEY_6=your_gemini_api_key_6
GEMINI_API_KEY_7=your_gemini_api_key_7
GEMINI_API_KEY_8=your_gemini_api_key_8
GEMINI_API_KEY_9=your_gemini_api_key_9
GEMINI_API_KEY_10=your_gemini_api_key_10

########################
# Gemini Fallback Strategy
########################
GEMINI_ENABLE_FALLBACK=true
GEMINI_FALLBACK_ON_429=true
GEMINI_FALLBACK_ON_QUOTA_ERROR=true
GEMINI_ROTATE_KEY_ON_ERROR=true

########################
# Product API (Chatbot)
########################
API_PRODUCT_BASE_URL=http://localhost:8081/api/v1/products
