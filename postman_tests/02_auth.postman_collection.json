        {
          "name": "POST /api/v1/auth/forgot-password/request - Yêu cầu đặt lại mật khẩu",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/forgot-password/request",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "forgot-password",
                "request"
              ],
              "query": []
            },
            "description": "Gửi OTP đến email để đặt lại mật khẩu\n\noperationId: requestPasswordReset",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"string\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is successful or expected error', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 204, 400, 401, 403, 404, 409]);",
                  "});",
                  "",
                  "if (pm.response.headers.get('Content-Type') && pm.response.headers.get('Content-Type').includes('application/json')) {",
                  "  pm.test('Response is valid JSON', function () { pm.response.json(); });",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
