        {
          "name": "Lọc sản phẩm đa tiêu chí",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/filter",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "products",
                "filter"
              ]
            },
            "description": "Lọc sản phẩm theo nhiều tiêu chí cùng lúc: danh mục, thương hiệu, giá, RAM, storage, pin, màn hình, OS, đánh giá, trạng thái kho",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryIds\": [\n    1\n  ],\n  \"brandIds\": [\n    1\n  ],\n  \"minPrice\": 5000000,\n  \"maxPrice\": 30000000,\n  \"ramOptions\": [\n    \"string\"\n  ],\n  \"storageOptions\": [\n    \"string\"\n  ],\n  \"minBattery\": 4000,\n  \"maxBattery\": 6000,\n  \"screenSizeOptions\": [\n    \"string\"\n  ],\n  \"osOptions\": [\n    \"string\"\n  ],\n  \"minRating\": 4.0,\n  \"maxRating\": 4.5,\n  \"inStockOnly\": true,\n  \"hasDiscountOnly\": true,\n  \"sortBy\": \"price\",\n  \"sortDirection\": \"asc\",\n  \"page\": 0,\n  \"size\": 20\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
