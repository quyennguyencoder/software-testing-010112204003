          "name": "Tạo đơn hàng mới",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status should be 201\", function() {",
                  "    pm.expect(pm.response.code).to.equal(201);",
                  "});",
                  "",
                  "let body;",
                  "try {",
                  "    body = pm.response.json();",
                  "} catch (e) {",
                  "    console.error(\"Response is not valid JSON or is empty:\", pm.response.text());",
                  "}",
                  "",
                  "if (body) {",
                  "    pm.test(\"Success should be true\", function() {",
                  "        pm.expect(body.success).to.equal(true);",
                  "    });",
                  "",
                  "    pm.test(\"Order ID exists\", function() {",
                  "        pm.expect(body.data.orderId).to.not.equal(null);",
                  "    });",
                  "",
                  "    pm.environment.set(\"orderId\", body.data.orderId);",
                  "    pm.environment.set(\"orderCode\", body.data.orderCode);",
                  "",
                  "    console.log(\"Saved orderId:\", body.data.orderId);",
                  "    console.log(\"Saved orderCode:\", body.data.orderCode);",
                  "}"
                ],
                "type": "text/javascript",
