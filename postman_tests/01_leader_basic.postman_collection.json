{
  "info": {
    "name": "PhoneHub - 01 Leader Basic",
    "description": "Simple public checks for leader/demo: health, public brands, categories, and locations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
