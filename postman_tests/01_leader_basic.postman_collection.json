  "item": [
    {
      "name": "Brand (Public)",
      "item": [
        {
          "name": "GET /api/v1/brands - Lấy danh sách tất cả thương hiệu",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/brands",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "brands"
              ],
              "query": []
            },
            "description": "Trả về danh sách tất cả thương hiệu, sắp xếp theo tên. **API này là công khai, không cần xác thực.**\n\noperationId: getAllBrands"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is successful or expected error', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 204, 400, 401, 403, 404, 409]);",
                  "});",
                  "",
                  "if (pm.response.headers.get('Content-Type') && pm.response.headers.get('Content-Type').includes('application/json')) {",
                  "  pm.test('Response is valid JSON', function () { pm.response.json(); });",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
