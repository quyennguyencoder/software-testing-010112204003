            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/best-selling?limit=1&page=1&size=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "products",
                "best-selling"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "1",
                  "disabled": true,
                  "description": "Số lượng giới hạn sản phẩm (không pagination)"
                },
                {
                  "key": "page",
                  "value": "1",
                  "disabled": true,
                  "description": "Số trang (bắt đầu từ 0)"
                },
                {
                  "key": "size",
                  "value": "1",
                  "disabled": true,
                  "description": "Số sản phẩm mỗi trang"
                }
              ]
            },
            "description": "Lấy danh sách sản phẩm bán chạy nhất theo lượt bán. Sử dụng limit để lấy N sản phẩm đầu tiên, hoặc dùng page/size để phân trang\n\noperationId: getBestSellingProducts"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is successful or expected error', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 204, 400, 401, 403, 404, 409]);",
                  "});",
