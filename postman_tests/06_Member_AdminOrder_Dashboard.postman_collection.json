  "item": [
    {
      "name": "01_Login_Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();\r",
              "// Kiểm tra cấu trúc trả về từ backend của bạn (thường là json.data.accessToken hoặc json.accessToken)\r",
              "const token = json.accessToken || (json.data && json.data.accessToken);\r",
              "\r",
              "if (token) {\r",
              "    pm.environment.set(\"adminAccessToken\", token);\r",
              "    pm.environment.set(\"accessToken\", token); // Đề phòng nhóm dùng tên biến này\r",
              "    console.log(\"Đã tự động cập nhật Admin Token mới!\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"usernameOrEmail\": \"admin\",\r\n    \"password\": \"Password@123\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:8081/api/v1/auth/login",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8081",
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "response": []
