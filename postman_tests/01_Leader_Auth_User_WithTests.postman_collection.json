  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const suffix = Date.now().toString();",
          "pm.environment.set(\"uniqueSuffix\", suffix);",
          "",
          "if (!pm.environment.get(\"userPassword\")) pm.environment.set(\"userPassword\", \"Password@123\");",
          "if (!pm.environment.get(\"adminPassword\")) pm.environment.set(\"adminPassword\", \"Password@123\");",
          "",
          "pm.environment.set(\"currentEmail\", `user_${suffix}@test.com`);",
          "pm.environment.set(\"currentUsername\", `user_${suffix}`);",
          "pm.environment.set(\"negativeProductId\", pm.environment.get(\"negativeProductId\") || \"999999999\");",
          "pm.environment.set(\"negativeOrderId\", pm.environment.get(\"negativeOrderId\") || \"999999999\");"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test(\"No server error\", () => { pm.expect(pm.response.code).to.be.below(500); });",
          "pm.test(\"Response time < 2000ms\", () => { pm.expect(pm.response.responseTime).to.be.below(2000); });",
          "pm.test(\"Response is JSON when body exists\", () => {",
          "  if (pm.response.text()) pm.expect(pm.response.headers.get(\"Content-Type\") || \"\").to.include(\"application/json\");",
          "});",
          "",
          "if (pm.response.text() && (pm.response.headers.get(\"Content-Type\") || \"\").includes(\"application/json\")) {",
          "  const json = pm.response.json();",
          "  const data = json.data || json;",
          "  const url = pm.request.url.toString();",
          "  const requestName = pm.info.requestName.toLowerCase();",
          "",
          "  if (data.accessToken) {",
          "    if (requestName.includes(\"admin\")) pm.environment.set(\"adminAccessToken\", data.accessToken);",
          "    else pm.environment.set(\"accessToken\", data.accessToken);",
          "  }",
          "  if (data.refreshToken) pm.environment.set(\"refreshToken\", data.refreshToken);",
          "  if (data.user && data.user.id) pm.environment.set(\"userId\", data.user.id);",
          "",
          "  const id = data.id || data.productId || data.orderId || data.addressId || data.cartItemId || data.guestCartId;",
          "  if (id) pm.environment.set(\"currentResourceId\", id);",
          "",
          "  if (id && url.includes(\"/admin/products\")) { pm.environment.set(\"createdProductId\", id); pm.environment.set(\"productId\", id); }",
          "  if (id && url.includes(\"/admin/categories\")) { pm.environment.set(\"createdCategoryId\", id); pm.environment.set(\"categoryId\", id); }",
          "  if (id && url.includes(\"/admin/brands\")) { pm.environment.set(\"createdBrandId\", id); pm.environment.set(\"brandId\", id); }",
          "  if (id && url.includes(\"/user/addresses\")) { pm.environment.set(\"createdAddressId\", id); pm.environment.set(\"addressId\", id); }",
          "  if (id && url.includes(\"/orders\")) { pm.environment.set(\"createdOrderId\", id); pm.environment.set(\"orderId\", id); }",
          "  if (id && url.includes(\"/admin/promotions\")) { pm.environment.set(\"createdPromotionId\", id); pm.environment.set(\"promotionId\", id); }",
          "  if (id && url.includes(\"/admin/promotion-templates\")) { pm.environment.set(\"createdPromotionTemplateId\", id); pm.environment.set(\"promotionTemplateId\", id); }",
          "  if (id && url.includes(\"/cart/items\")) pm.environment.set(\"cartItemId\", id);",
          "  if (id && url.includes(\"/guest-cart\")) pm.environment.set(\"guestCartId\", id);",
          "  if (data.orderCode) { pm.environment.set(\"createdOrderCode\", data.orderCode); pm.environment.set(\"orderCode\", data.orderCode); }",
          "}"
        ]
      }
    }
  ],
