{
  "info": {
    "_postman_id": "5137f3f8-462d-4ad5-b650-1b216d205776",
    "name": "🔐 [Leader] Authentication & User",
    "description": "Leader Collection - Authentication, User Profile & Health Check\nDành cho Leader: Các API cơ bản nhất, dễ kiểm thử (13 endpoints)\n\n📋 **Hướng dẫn chạy collection:**\n1. Import environment `UTE_PhoneHub.postman_environment.json`\n2. Cập nhật `testEmail` và `testPassword` trong environment\n3. Chạy theo thứ tự: Health → Register → Verify Email → Login → [các API khác]\n4. Token tự động lưu vào environment sau khi Login thành công",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Xác thực email đăng ký",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/verify-email",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "verify-email"
              ]
            },
            "description": "Xác thực email bằng mã OTP được gửi sau khi đăng ký",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"string\",\n  \"otp\": \"string\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// ⚠️ Cần điền OTP thật nhận từ email sau khi đăng ký",
                  "// Cập nhật biến môi trường 'otpCode' trước khi chạy",
                  "",
                  "const email = pm.environment.get(\"registerEmail\") || pm.environment.get(\"testEmail\");",
                  "const otp = pm.environment.get(\"otpCode\") || \"123456\"; // thay OTP thật vào đây",
                  "",
                  "pm.request.body.raw = JSON.stringify({",
                  "    email: email,",
                  "    otp: otp",
                  "});",
                  "",
                  "console.log(\"🔑 Xác thực email:\", email, \"| OTP:\", otp);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// ✅ TC01 - Xác thực OTP hợp lệ → 200",
                  "pm.test(\"TC01 - Xác thực email thành công (200)\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// ✅ TC02 - Response time",
                  "pm.test(\"TC02 - Response time dưới 3000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.test(\"TC03 - Response có message xác nhận\", function () {",
                  "        pm.expect(json).to.have.any.keys(\"message\", \"success\", \"data\");",
                  "    });",
                  "    console.log(\"✅ Email đã được xác thực\");",
                  "}",
                  "",
                  "// ❌ TC04 - OTP sai → expect 400/401",
                  "// Body: { \"email\": \"...\", \"otp\": \"000000\" } → phải trả lỗi",
                  "",
                  "// ❌ TC05 - OTP hết hạn → expect 400/410",
                  "// (OTP thường hết hạn sau 5-10 phút)",
                  "",
                  "// ❌ TC06 - Email không tồn tại → expect 404/400"
                ]
              }
            }
          ]
        },
        {
          "name": "Đăng ký tài khoản mới",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "description": "Tạo một tài khoản khách hàng mới",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"string\",\n  \"fullName\": \"string\",\n  \"email\": \"string\",\n  \"phoneNumber\": \"string\",\n  \"gender\": \"string\",\n  \"dateOfBirth\": \"string\",\n  \"password\": \"string\",\n  \"confirmPassword\": \"string\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Tạo email ngẫu nhiên để tránh trùng lặp khi chạy nhiều lần",
                  "const timestamp = Date.now();",
                  "const testEmail = `testuser_${timestamp}@example.com`;",
                  "const testUsername = `testuser_${timestamp}`;",
                  "",
                  "pm.environment.set(\"registerEmail\", testEmail);",
                  "pm.environment.set(\"registerUsername\", testUsername);",
                  "pm.environment.set(\"registerPassword\", \"Password@123\");",
                  "",
                  "// Cập nhật body với dữ liệu ngẫu nhiên",
                  "pm.request.body.raw = JSON.stringify({",
                  "    username: testUsername,",
                  "    fullName: \"Test User \" + timestamp,",
                  "    email: testEmail,",
                  "    phoneNumber: \"0901234567\",",
                  "    gender: \"MALE\",",
                  "    dateOfBirth: \"2000-01-01\",",
                  "    password: \"Password@123\",",
                  "    confirmPassword: \"Password@123\"",
                  "});",
                  "",
                  "console.log(\"📧 Đăng ký với email:\", testEmail);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// ✅ TC01 - Đăng ký thành công → 200 hoặc 201",
                  "pm.test(\"TC01 - Đăng ký thành công (200/201)\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "// ✅ TC02 - Response time",
                  "pm.test(\"TC02 - Response time dưới 3000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "",
                  "    // ✅ TC03 - Response có data",
                  "    pm.test(\"TC03 - Response có trường data hoặc message\", function () {",
                  "        pm.expect(json).to.have.any.keys(\"data\", \"message\", \"success\");",
                  "    });",
                  "",
                  "    // ✅ TC04 - Lưu lại email để dùng tiếp ở verify-email",
                  "    console.log(\"✅ Đăng ký thành công, email:\", pm.environment.get(\"registerEmail\"));",
                  "    console.log(\"📌 Tiếp theo: Gọi 'Xác thực email đăng ký' với email này + OTP nhận qua mail\");",
                  "}",
                  "",
                  "// ❌ TC05 - Đăng ký với email đã tồn tại → expect 4xx",
                  "// (Test case này cần chạy request lần 2 sau khi đã đăng ký xong)",
                  "",
                  "// ❌ TC06 - Validation: password không khớp confirmPassword",
                  "// Body mẫu: { \"password\": \"abc\", \"confirmPassword\": \"xyz\" } → expect 400"
                ]
              }
            }
          ]
        },
        {
          "name": "Đăng ký tài khoản Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register/admin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register",
                "admin"
              ]
            },
            "description": "Tạo một tài khoản admin mới",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"string\",\n  \"fullName\": \"string\",\n  \"email\": \"string\",\n  \"phoneNumber\": \"string\",\n  \"gender\": \"string\",\n  \"dateOfBirth\": \"string\",\n  \"password\": \"string\",\n  \"confirmPassword\": \"string\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const timestamp = Date.now();",
                  "const adminEmail = `admin_${timestamp}@example.com`;",
                  "pm.environment.set(\"adminRegisterEmail\", adminEmail);",
                  "",
                  "pm.request.body.raw = JSON.stringify({",
                  "    username: `admin_${timestamp}`,",
                  "    fullName: \"Admin Test \" + timestamp,",
                  "    email: adminEmail,",
                  "    phoneNumber: \"0909999888\",",
                  "    gender: \"MALE\",",
                  "    dateOfBirth: \"1990-05-15\",",
                  "    password: \"Admin@123456\",",
                  "    confirmPassword: \"Admin@123456\"",
                  "});",
                  "",
                  "console.log(\"👤 Đăng ký admin với email:\", adminEmail);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// ✅ TC01 - Đăng ký admin thành công",
                  "pm.test(\"TC01 - Đăng ký admin trả về 200/201\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "// ✅ TC02 - Response time",
                  "pm.test(\"TC02 - Response time dưới 3000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.test(\"TC03 - Response body hợp lệ\", function () {",
                  "        pm.expect(json).to.be.an(\"object\");",
                  "    });",
                  "    console.log(\"✅ Admin registered:\", pm.environment.get(\"adminRegisterEmail\"));",
                  "}",
                  "",
                  "// ❌ TC04 - Thiếu trường bắt buộc → 400",
                  "// ❌ TC05 - Email không đúng format → 400",
                  "// ❌ TC06 - Password quá ngắn / không đủ mạnh → 400"
                ]
              }
            }
          ]
        },
        {
          "name": "Làm mới access token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "refresh"
              ]
            },
            "description": "Sử dụng refresh token để lấy access token mới",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"string\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const refreshToken = pm.environment.get(\"refreshToken\");",
                  "if (!refreshToken) {",
                  "    console.warn(\"⚠️ Chưa có refreshToken trong environment. Hãy chạy 'Đăng nhập' trước.\");",
                  "}",
                  "",
                  "pm.request.body.raw = JSON.stringify({",
                  "    refreshToken: refreshToken || \"\"",
                  "});",
                  "",
                  "console.log(\"🔄 Làm mới token...\");"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// ✅ TC01 - Refresh token hợp lệ → 200",
                  "pm.test(\"TC01 - Làm mới token thành công (200)\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// ✅ TC02 - Response time",
                  "pm.test(\"TC02 - Response time dưới 3000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "",
                  "    // ✅ TC03 - Có accessToken mới trong response",
                  "    pm.test(\"TC03 - Response chứa accessToken mới\", function () {",
                  "        const newToken = json.accessToken || json.data?.accessToken || json.token;",
                  "        pm.expect(newToken).to.not.be.undefined;",
                  "        pm.expect(newToken).to.not.be.empty;",
                  "",
                  "        // 💾 Cập nhật accessToken mới",
                  "        pm.environment.set(\"accessToken\", newToken);",
                  "        console.log(\"✅ accessToken đã được cập nhật mới\");",
                  "    });",
                  "",
                  "    // ✅ TC04 - accessToken mới phải khác token cũ (nếu có)",
                  "    pm.test(\"TC04 - Token mới có định dạng JWT hợp lệ\", function () {",
                  "        const token = pm.environment.get(\"accessToken\");",
                  "        pm.expect(token.split(\".\").length).to.equal(3);",
                  "    });",
                  "}",
                  "",
                  "// ❌ TC05 - refreshToken không hợp lệ → 401",
                  "// Body: { \"refreshToken\": \"invalid.token.here\" }",
                  "",
                  "// ❌ TC06 - refreshToken hết hạn → 401/403",
                  "// ❌ TC07 - Body rỗng → 400"
                ]
              }
            }
          ]
        },
        {
          "name": "Đăng xuất",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "logout"
              ]
            },
            "description": "Kết thúc phiên đăng nhập"
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.environment.get(\"accessToken\");",
                  "if (!token) {",
                  "    console.warn(\"⚠️ Chưa có accessToken. Hãy chạy 'Đăng nhập' trước.\");",
                  "}",
                  "console.log(\"👋 Đăng xuất...\");"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// ✅ TC01 - Đăng xuất thành công → 200",
                  "pm.test(\"TC01 - Đăng xuất thành công (200)\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// ✅ TC02 - Response time",
                  "pm.test(\"TC02 - Response time dưới 2000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    // 🧹 Xóa token khỏi environment sau khi logout",
                  "    pm.environment.set(\"accessToken\", \"\");",
                  "    pm.environment.set(\"refreshToken\", \"\");",
                  "    console.log(\"🧹 Token đã được xóa khỏi environment\");",
                  "}",
                  "",
                  "// ❌ TC03 - Logout khi chưa đăng nhập (không có token) → 401",
                  "// ❌ TC04 - Dùng lại token sau khi logout → 401 (token đã bị blacklist)"
                ]
              }
            }
          ]
        },
        {
          "name": "Đăng nhập",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Đăng nhập bằng username hoặc email và mật khẩu",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usernameOrEmail\": \"string\",\n  \"password\": \"string\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Dùng biến môi trường testEmail & testPassword",
                  "// Đảm bảo tài khoản đã được tạo và xác thực email trước",
                  "",
                  "pm.request.body.raw = JSON.stringify({",
                  "    usernameOrEmail: pm.environment.get(\"testEmail\"),",
                  "    password: pm.environment.get(\"testPassword\")",
                  "});",
                  "",
                  "console.log(\"🔐 Đăng nhập với:\", pm.environment.get(\"testEmail\"));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// ✅ TC01 - Login thành công → 200",
                  "pm.test(\"TC01 - Đăng nhập thành công (200)\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// ✅ TC02 - Response time",
                  "pm.test(\"TC02 - Response time dưới 3000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "",
                  "    // ✅ TC03 - Response có accessToken",
                  "    pm.test(\"TC03 - Response chứa accessToken\", function () {",
                  "        const token = json.accessToken",
                  "            || json.data?.accessToken",
                  "            || json.token",
                  "            || json.data?.token;",
                  "        pm.expect(token).to.not.be.undefined;",
                  "        pm.expect(token).to.not.be.empty;",
                  "",
                  "        // 💾 Lưu token vào environment để các request khác dùng",
                  "        pm.environment.set(\"accessToken\", token);",
                  "        console.log(\"💾 accessToken đã lưu vào environment\");",
                  "    });",
                  "",
                  "    // ✅ TC04 - Response có refreshToken",
                  "    pm.test(\"TC04 - Response chứa refreshToken\", function () {",
                  "        const refreshToken = json.refreshToken",
                  "            || json.data?.refreshToken;",
                  "        if (refreshToken) {",
                  "            pm.environment.set(\"refreshToken\", refreshToken);",
                  "            console.log(\"💾 refreshToken đã lưu vào environment\");",
                  "        }",
                  "        // Không fail nếu không có refreshToken (một số API không trả về ngay)",
                  "        pm.expect(true).to.be.true;",
                  "    });",
                  "",
                  "    // ✅ TC05 - Token có định dạng JWT (3 phần ngăn cách bởi dấu chấm)",
                  "    pm.test(\"TC05 - accessToken có định dạng JWT hợp lệ\", function () {",
                  "        const token = pm.environment.get(\"accessToken\");",
                  "        if (token) {",
                  "            const parts = token.split(\".\");",
                  "            pm.expect(parts.length).to.equal(3);",
                  "        }",
                  "    });",
                  "",
                  "    // ✅ TC06 - Response có thông tin user",
                  "    pm.test(\"TC06 - Response chứa thông tin người dùng\", function () {",
                  "        const hasUser = json.user || json.data?.user",
                  "            || json.userId || json.data?.userId",
                  "            || json.email || json.data?.email;",
                  "        pm.expect(hasUser).to.not.be.undefined;",
                  "    });",
                  "",
                  "    // Lưu userId nếu có",
                  "    const userId = json.userId || json.data?.userId || json.user?.id || json.data?.user?.id;",
                  "    if (userId) {",
                  "        pm.environment.set(\"userId\", userId);",
                  "        console.log(\"💾 userId đã lưu:\", userId);",
                  "    }",
                  "}",
                  "",
                  "// ❌ TC07 - Sai mật khẩu → 401",
                  "// Body: { \"usernameOrEmail\": \"...\", \"password\": \"SaiMatKhau123\" }",
                  "",
                  "// ❌ TC08 - Email không tồn tại → 401/404",
                  "// Body: { \"usernameOrEmail\": \"khongtontai@abc.com\", \"password\": \"...\" }",
                  "",
                  "// ❌ TC09 - Thiếu password → 400",
                  "// Body: { \"usernameOrEmail\": \"...\" }",
                  "",
                  "// ❌ TC10 - Body rỗng → 400"
                ]
              }
            }
          ]
        },
        {
          "name": "Xác thực OTP và đặt lại mật khẩu",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/forgot-password/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "forgot-password",
                "verify"
              ]
            },
            "description": "Xác thực mã OTP và cập nhật mật khẩu mới",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"string\",\n  \"otp\": \"string\",\n  \"newPassword\": \"string\",\n  \"confirmPassword\": \"string\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// ⚠️ Cập nhật biến 'otpCode' trong environment với OTP thật từ email",
                  "const email = pm.environment.get(\"testEmail\");",
                  "const otp = pm.environment.get(\"otpCode\") || \"123456\";",
                  "const newPass = \"NewPassword@456\";",
                  "",
                  "pm.request.body.raw = JSON.stringify({",
                  "    email: email,",
                  "    otp: otp,",
                  "    newPassword: newPass,",
                  "    confirmPassword: newPass",
