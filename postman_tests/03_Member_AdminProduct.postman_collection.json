  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const suffix = pm.environment.get(\"uniqueSuffix\") || Date.now().toString();",
          "pm.environment.set(\"uniqueSuffix\", suffix);",
          "pm.environment.set(\"todayIso\", new Date().toISOString().slice(0, 19));",
          "pm.environment.set(\"futureIso\", new Date(Date.now() + 86400000 * 30).toISOString().slice(0, 19));",
          "pm.environment.set(\"yesterdayIso\", new Date(Date.now() - 86400000).toISOString().slice(0, 19));",
          "if (!pm.environment.get(\"currentEmail\")) pm.environment.set(\"currentEmail\", `user_${suffix}@test.com`);",
          "if (!pm.environment.get(\"currentUsername\")) pm.environment.set(\"currentUsername\", `user_${suffix}`);",
          "if (!pm.environment.get(\"userEmail\")) pm.environment.set(\"userEmail\", pm.environment.get(\"currentEmail\"));",
          "if (!pm.environment.get(\"userPassword\")) pm.environment.set(\"userPassword\", \"Password@123\");",
          "if (!pm.environment.get(\"adminPassword\")) pm.environment.set(\"adminPassword\", \"Password@123\");",
          "if (!pm.environment.get(\"resetPassword\")) pm.environment.set(\"resetPassword\", \"Password@1234\");"
        ]
      }
