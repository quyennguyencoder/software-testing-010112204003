        {
          "name": "Lấy chi tiết sản phẩm (Admin)",
          "event": [
            { 
              "listen": "test",
              "script": {
                "exec": [
                  "// Test Case 01: Kiểm tra mã trạng thái HTTP (HTTP Status Code)\r",
                  "pm.test(\"TC01: Mã trạng thái phản hồi phải là 200 OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Test Case 02: Kiểm tra hiệu năng API (Response Time)\r",
                  "pm.test(\"TC02: Thời gian phản hồi phải dưới 500ms để đảm bảo hiệu suất\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
                  "});\r",
                  "\r",
                  "// Test Case 03: Kiểm định cấu trúc vỏ phản hồi (Response Wrapper/Payload)\r",
                  "pm.test(\"TC03: Phản hồi phải tuân thủ chuẩn định dạng API của hệ thống\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    \r",
                  "    // Xác thực các cờ trạng thái (Status Flags)\r",
                  "    pm.expect(jsonData.success).to.be.true;\r",
                  "    pm.expect(jsonData.status).to.eql(200);\r",
                  "    \r",
                  "    // Xác thực sự tồn tại của đối tượng mang dữ liệu chính (Data Payload)\r",
                  "    pm.expect(jsonData).to.have.property(\"data\");\r",
                  "});\r",
                  "\r",
                  "// Test Case 04: Kiểm định tính toàn vẹn của dữ liệu thực thể (Entity Data Integrity)\r",
                  "pm.test(\"TC04: Đối tượng Product phải chứa đầy đủ các thuộc tính bắt buộc\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    \r",
                  "    // Trích xuất đối tượng Product từ payload\r",
                  "    var product = jsonData.data; \r",
                  "    \r",
                  "    // Xác thực các trường thông tin cơ bản\r",
                  "    pm.expect(product).to.have.property('id');\r",
                  "    pm.expect(product).to.have.property('name');\r",
                  "    \r",
                  "    // Xác thực kiểu dữ liệu của các thuộc tính danh sách (Collections/Arrays)\r",
                  "    pm.expect(product.templates).to.be.an('array');\r",
                  "    pm.expect(product.images).to.be.an('array');\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
