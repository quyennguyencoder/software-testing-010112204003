    {
      "name": "ADM01 - Khong token tra 401",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const testCaseId = \"ADM01\";",
              "const expectedStatusCodes = [401];",
              "",
              "// Lấy ngưỡng thời gian từ môi trường, mặc định 3000ms",
              "const responseTimeThresholdMs = Number(pm.environment.get(\"responseTimeThresholdMs\") || 3000);",
              "const contentType = pm.response.headers.get(\"Content-Type\") || \"\";",
              "",
              "// 1. Kiểm tra mã trạng thái (Quan trọng nhất)",
              "pm.test(`[${testCaseId}] Hệ thống từ chối truy cập và trả về mã ${expectedStatusCodes.join(\"/\")}`, () => {",
              "    pm.expect(pm.response.code).to.be.oneOf(expectedStatusCodes);",
              "});",
              "",
              "// 2. Đảm bảo server không bị crash (không trả về lỗi 5xx)",
              "pm.test(`[${testCaseId}] Không có lỗi Server (No 5xx errors)`, () => {",
              "    pm.expect(pm.response.code).to.be.below(500);",
              "});",
              "",
              "// 3. Kiểm tra tốc độ phản hồi",
              "pm.test(`[${testCaseId}] Thời gian phản hồi dưới ${responseTimeThresholdMs}ms`, () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(responseTimeThresholdMs);",
              "});",
              "",
              "// 4. Nếu có Body trả về, đảm bảo nó là định dạng JSON",
              "pm.test(`[${testCaseId}] Dữ liệu trả về (nếu có) phải là JSON`, () => {",
              "    if (pm.response.text()) {",
              "        pm.expect(contentType).to.include(\"application/json\");",
              "    }",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
