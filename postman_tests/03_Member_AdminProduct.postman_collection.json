    {
      "name": "ADM03 - Admin tao category thanh cong",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const testCaseId = \"ADM03\";",
              "const expectedStatusCodes = [200, 201];",
              "const responseTimeThresholdMs = Number(pm.environment.get(\"responseTimeThresholdMs\") || 3000);",
              "",
              "// 1. Kiểm tra mã trạng thái (Tạo thành công)",
              "pm.test(`[${testCaseId}] Tạo danh mục thành công trả về mã ${expectedStatusCodes.join(\"/\")}`, () => {",
              "    pm.expect(pm.response.code).to.be.oneOf(expectedStatusCodes);",
              "});",
              "",
              "// 2. Kiểm tra thời gian phản hồi",
              "pm.test(`[${testCaseId}] Thời gian phản hồi dưới ${responseTimeThresholdMs}ms`, () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(responseTimeThresholdMs);",
              "});",
              "",
              "// 3. Kiểm tra dữ liệu và mớm ID tự động cho CI/CD",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "    const jsonData = pm.response.json();",
              "    ",
              "    // Đảm bảo dữ liệu trả về nằm trong cục 'data' và có 'id'",
              "    pm.test(`[${testCaseId}] Trả về thông tin danh mục có chứa ID`, () => {",
              "        pm.expect(jsonData).to.have.property('data');",
              "        pm.expect(jsonData.data).to.have.property('id');",
              "    });",
              "",
              "    // BẮT BUỘC LƯU VÀO currentResourceId ĐỂ BOT CI/CD CHẠY ĐƯỢC CÁC BƯỚC PUT/DELETE",
              "    if (jsonData.data && jsonData.data.id) {",
              "        const newId = jsonData.data.id;",
              "        ",
              "        // Lưu biến xài chung cho CRUD",
              "        pm.environment.set(\"currentResourceId\", newId);",
              "        ",
              "        // Lưu thêm biến dự phòng nếu API khác cần",
              "        pm.environment.set(\"categoryId\", newId); ",
              "        ",
              "        console.log(`[${testCaseId}] CI/CD Ready! Đã lưu currentResourceId = ${newId}`);",
              "    }",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
