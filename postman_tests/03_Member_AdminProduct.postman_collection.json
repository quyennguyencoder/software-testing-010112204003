  "item": [
    {
      "name": "Đăng nhập Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Kiểm tra chắc chắn API gọi thành công (Status 200)\r",
              "pm.test(\"Đăng nhập thành công với mã 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Chuyển phản hồi của Backend thành đối tượng JSON\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "// Tìm đúng đường dẫn đến chỗ giấu Token và lưu lại\r",
              "if (jsonData && jsonData.data && jsonData.data.accessToken) {\r",
              "    var token = jsonData.data.accessToken;\r",
              "    \r",
              "    // Lưu Token vào biến môi trường tên là \"adminAccessToken\"\r",
              "    pm.environment.set(\"adminAccessToken\", token);\r",
              "    \r",
              "    // In ra console để tự tin là đã lưu thành công\r",
              "    console.log(\"Hệ thống đã tự động chộp được Token: \" + token);\r",
              "} else {\r",
              "    console.log(\"Lỗi: Không tìm thấy accessToken trong phản hồi!\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
